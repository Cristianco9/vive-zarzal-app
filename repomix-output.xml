/* ==========================================================
   footer.css — Vive Zarzal footer styles (full-width background)
   Load this AFTER root.css so it can override token defaults
   Comments in English
   ========================================================== */

/* Footer background color token — change here or in root.css if you prefer */
:root {
  --footer-bg: #4a4a4a; /* dark band color across full width */
  --footer-box-bg: transparent; /* keep inner box transparent when background is full-width */
}

/* SITE FOOTER
   The footer background spans the full viewport width (full-bleed dark band).
   Content is centered and constrained inside .footer-inner.
*/
.site-footer {
  width: 100%;
  background: var(--footer-bg);
  padding: var(--space-6) 0; /* vertical padding for the band */
  color: var(--text-inverse);
  font-family: var(--font-family-primary);
  box-shadow: var(--shadow-sm);
}

/* INNER: constrained content */
.footer-inner {
  width: min(var(--container-lg), 84%);
  margin: 0 auto;
  padding: 0 var(--space-4);
  display: flex;
  justify-content: center;
}

/* BOX: optionally transparent to let .site-footer show as full-width band.
   Keeps centering and vertical spacing for text.
*/
.footer-box {
  background: var(--footer-box-bg);
  width: 100%;
  max-width: var(--container-md);
  border-radius: 0; /* remove rounding so band looks flush; set to var(--radius-sm) if you want rounding */
  padding: 0; /* we already provide vertical spacing on .site-footer */
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  text-align: center;
}

/* TYPOGRAPHY */
.footer-copy {
  color: #ffffff;
  font-size: var(--font-size-sm);
  margin: 0;
}

.footer-contact {
  color: #e6e6e6;
  font-size: var(--font-size-sm);
  margin: 0;
}

.footer-contact-link {
  color: var(--color-accent);
  text-decoration: underline;
  font-weight: var(--font-weight-medium);
}

/* Hover / focus states for accessibility */
.footer-contact-link:hover,
.footer-contact-link:focus {
  color: var(--color-accent-hover);
  text-decoration: none;
  outline: none;
  text-underline-offset: 3px;
}

/* RESPONSIVE: keep padding and readable font sizes on small screens */
@media (max-width: 600px) {
  .site-footer {
    padding: var(--space-6) var(--space-4);
  }
  .footer-inner {
    width: 92%;
  }
  .footer-copy,
  .footer-contact {
    font-size: var(--font-size-xs);
  }
}
</file>

<file path="src/public/styles/components/header.css">
/* ==========================================================
   header.css — Vive Zarzal header overrides
   Load this AFTER root.css so it can override token defaults
   ========================================================== */

/* Brand blue used for the "Vive Zarzal" text (adjustable) */
:root {
    --color-brand-blue: #0d6efd;
    /* adjust to match the exact blue in the design */
}

/* --------------------------
   NAVBAR BASE
   -------------------------- */
.site-header {
    background: var(--gray-100);
    height: var(--navbar-height);
    display: flex;
    align-items: center;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
}

/* --------------------------
   INNER CONTAINER: center + constrained width
   Mirrors the narrow horizontal band in the design
   -------------------------- */
.nav-inner {
    width: min(var(--container-lg), 84%);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-content: space-between;
    padding: 0 var(--space-4);
}

/* --------------------------
   BRAND
   -------------------------- */
.brand {
    font-family: var(--font-family-primary);
    font-weight: var(--font-weight-semibold);
    color: var(--color-brand-blue);
    text-decoration: none;
    font-size: var(--font-size-lg);
    padding: 0 var(--space-2);
}

/* --------------------------
   CENTER NAV MENU
   Displays menu items centered in the horizontal band
   -------------------------- */
.nav-menu {
    list-style: none;
    display: flex;
    gap: var(--space-8);
    align-items: center;
    margin: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
}

.nav-menu a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-normal);
    padding: calc(var(--space-2) / 1.25) var(--space-3);
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast), color var(--transition-fast);
}

.nav-menu a:hover,
.nav-menu a:focus {
    background: rgba(0, 0, 0, 0.03);
    outline: none;
}

/* --------------------------
   RIGHT-SIDE ACTIONS
   User icon, user label and login/logout buttons
   -------------------------- */
.nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 220px;
    justify-content: flex-end;
}

/* User icon button — simple, accessible button with svg icon */
.user-btn {
    background: transparent;
    border: none;
    color: var(--text-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    border-radius: var(--radius-pill);
    cursor: pointer;
}

.user-btn svg {
    display: block;
}

/* User label text to the right of the icon */
.user-label {
    color: var(--text-secondary);
    margin-left: 4px;
    margin-right: 8px;
    font-size: var(--font-size-sm);
}

/* Login button styled as a rounded, yellow pill like the design */
.btn-login {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-black);
    padding: 0.45rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    transition: background var(--transition-fast), transform var(--transition-fast);
}

.btn-login:hover,
.btn-login:focus {
    background: var(--color-primary);
    color: var(--color-white);
    transform: translateY(-1px);
}

/* Logout button: red pill style to indicate destructive action */
.btn-logout {
    display: inline-block;
    background: var(--color-danger);
    color: var(--color-white);
    padding: 0.45rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    border: 0;
    cursor: pointer;
    box-shadow: 0 1px 0 rgba(0, 0, 0);
}

/* Active menu link: color uses the primary token (yellow/orange)
   This makes the active item text appear in the brand yellow color. */
.nav-menu a.active {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
    /* subtle underline indicator (thin) to reinforce the active state */
    box-shadow: inset 0 -3px 0 var(--color-primary);
    border-radius: 2px;
}

/* Ensure active state preserves hover/keyboard styles */
.nav-menu a.active:hover,
.nav-menu a.active:focus {
    background: rgba(0, 0, 0, 0.03);
    color: var(--color-primary);
}

/* Optional: increase specificity when active to avoid inheritance */
.nav-menu>li>a.active {
    padding-bottom: calc(var(--space-2) / 1.25);
}
</file>


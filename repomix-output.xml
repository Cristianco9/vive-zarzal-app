    if (!cityId) {
      throw Boom.badRequest('No city ID provided');
    }

    try {
      const deletedRows = await City.destroy({
        where: { id: cityId }
      });

      if (!deletedRows) {
        throw Boom.notFound('City not found');
      }

      return { status: 'DELETED SUCCESSFULLY' };

    } catch (error) {
      if (Boom.isBoom(error)) throw error;

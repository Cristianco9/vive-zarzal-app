          </svg>
        </button>

        <span class="user-label">Invitado</span>

        <!-- "Regresar" button (blue) on the right as in the mock -->
        <a data-path="/app/v1/" onclick="redirect(this)" class="btn-back" role="button">Regresar</a>
      </div>
    </div>
  </nav>

  <!-- LOGIN MAIN CONTENT -->
  <main class="login-main" role="main">

<file path="src/public/styles/root.css">
/* ==========================================================
   VIVE ZARZAL - DESIGN TOKENS
   root.css
   ========================================================== */

:root {

  /* ========================================================
     COLORS
     ======================================================== */

  --color-primary: #E49A2E;
  --color-primary-hover: #C98420;
  --color-primary-light: #F5C87A;

  --color-secondary: #28A745;
  --color-secondary-hover: #218838;

  --color-accent: #17A2B8;
  --color-accent-hover: #138496;

  --color-success: #28A745;
  --color-warning: #FFC107;
  --color-danger: #DC3545;
  --color-info: #0DCAF0;

  /* Neutral palette */

  --color-white: #FFFFFF;
  --color-black: #000000;

  --gray-50: #F8F9FA;
  --gray-100: #F1F3F5;
  --gray-200: #E9ECEF;
  --gray-300: #DEE2E6;
  --gray-400: #CED4DA;
  --gray-500: #ADB5BD;
  --gray-600: #6C757D;
  --gray-700: #495057;
  --gray-800: #343A40;
  --gray-900: #212529;

  /* Backgrounds */

  --bg-body: #FFFFFF;
  --bg-body-alt: #F8F9FA;

  --bg-card: #FFFFFF;
  --bg-section: #F8F9FA;
  --bg-overlay: rgba(0, 0, 0, 0.4);

  /* Text */

  --text-primary: #212529;
  --text-secondary: #6C757D;
  --text-muted: #868E96;
  --text-inverse: #FFFFFF;

  /* ========================================================
     TYPOGRAPHY
     ======================================================== */

  --font-family-primary: "Poppins", sans-serif;

  --font-size-xs: 0.75rem;      /* 12px */
  --font-size-sm: 0.875rem;     /* 14px */
  --font-size-md: 1rem;         /* 16px */
  --font-size-lg: 1.125rem;     /* 18px */
  --font-size-xl: 1.25rem;      /* 20px */
  --font-size-2xl: 1.5rem;      /* 24px */
  --font-size-3xl: 2rem;        /* 32px */
  --font-size-4xl: 2.5rem;      /* 40px */

  --font-weight-light: 300;
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  --line-height-tight: 1.2;
  --line-height-normal: 1.5;
  --line-height-loose: 1.8;

  /* ========================================================
     SPACING SYSTEM (8px GRID)
     ======================================================== */

  --space-0: 0;
  --space-1: 0.25rem;  /* 4px */
  --space-2: 0.5rem;   /* 8px */
  --space-3: 0.75rem;  /* 12px */
  --space-4: 1rem;     /* 16px */
  --space-5: 1.25rem;  /* 20px */
  --space-6: 1.5rem;   /* 24px */
  --space-8: 2rem;     /* 32px */
  --space-10: 2.5rem;  /* 40px */
  --space-12: 3rem;    /* 48px */
  --space-16: 4rem;    /* 64px */

  /* ========================================================
     BORDER RADIUS
     ======================================================== */

  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-2xl: 24px;
  --radius-pill: 9999px;

  /* ========================================================
     SHADOWS
     ======================================================== */

  --shadow-xs:
    0 1px 2px rgba(0,0,0,0.05);

  --shadow-sm:
    0 2px 4px rgba(0,0,0,0.08);

  --shadow-md:
    0 5px 10px rgba(0,0,0,0.12);

  --shadow-lg:
    0 8px 20px rgba(0,0,0,0.15);

  --shadow-xl:
    0 12px 30px rgba(0,0,0,0.20);

  /* ========================================================
     TRANSITIONS
     ======================================================== */

  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s ease;
  --transition-slow: 0.5s ease;

  /* ========================================================
     LAYOUT
     ======================================================== */

  --container-sm: 540px;
  --container-md: 720px;
  --container-lg: 960px;
  --container-xl: 1140px;
  --container-xxl: 1320px;

  --navbar-height: 70px;
  --footer-height: 80px;

  /* ========================================================
     Z-INDEX
     ======================================================== */

  --z-dropdown: 1000;
  --z-sticky: 1020;
  --z-fixed: 1030;
  --z-modal-backdrop: 1040;
  --z-modal: 1050;
  --z-toast: 1100;

  /* ========================================================
     IMAGES
     ======================================================== */

  --card-image-height: 220px;
  --hero-min-height: 100vh;

  /* ========================================================
     GRADIENTS
     ======================================================== */

  --gradient-body:
    linear-gradient(
      to right,
      #F8F9FA,
      #EAF4FF
    );

  --gradient-primary:
    linear-gradient(
      135deg,
      #E49A2E,
      #F5C87A
    );
}

/* ==========================================================
   DARK THEME
   ========================================================== */

[data-theme="dark"] {

  --bg-body: #121212;
  --bg-body-alt: #1A1A1A;

  --bg-card: #1E1E1E;
  --bg-section: #1E1E1E;

  --text-primary: #F0F0F0;
  --text-secondary: #CFCFCF;
  --text-muted: #AAAAAA;

  --gray-900: #F8F9FA;

  --shadow-md:
    0 5px 15px rgba(0,0,0,0.35);

  --shadow-lg:
    0 10px 30px rgba(0,0,0,0.45);
}

/* ==========================================================
   GLOBAL ELEMENT TOKENS
   ========================================================== */

body {
  font-family: var(--font-family-primary);
  background: var(--bg-body);
  color: var(--text-primary);
  line-height: var(--line-height-normal);
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-normal);
}

.card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
}

.btn-primary-custom {
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: var(--radius-md);
  transition: all var(--transition-normal);
}

.btn-primary-custom:hover {
  background: var(--color-primary-hover);
}

.section-title {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

.text-primary-brand {
  color: var(--color-primary);
}

.shadow-brand {
  box-shadow: var(--shadow-md);
}
</file>

<file path="src/public/styles/selectRole.css">
header.site-header.select-role-header {
  background: var(--bg-page, #fff);
  padding: calc(var(--space-4, 16px)) calc(var(--space-6, 24px));
  box-shadow: 0 1px 8px rgba(16, 24, 40, 0.04);
  position: sticky;
  top: 0;
  z-index: 60;
  backdrop-filter: blur(6px);
}

.select-role-header .header-inner {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4, 16px);
}

/* Brand */
.select-role-header .brand {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2, 8px);
  text-decoration: none;
  color: inherit;
}

.select-role-header .brand-logo {
  display: block;
  height: 40px;
  width: auto;
  object-fit: contain;
  -webkit-user-drag: none;
}

/* Si quieres texto al lado del logo */
.select-role-header .brand .brand-text {
  font-size: var(--font-size-md, 16px);
  font-weight: var(--font-weight-semibold, 600);
  color: var(--color-title, #0f172a);
}

/* Nav / acciones */
.select-role-header .header-actions {
  display: flex;
  align-items: center;
  gap: var(--space-3, 12px);
}

.select-role-header .btn-text {
  color: var(--color-primary, #0b5cff);
  font-weight: var(--font-weight-medium, 500);
  text-decoration: none;
  background: transparent;
  border: 1px solid transparent;
  padding: 8px 12px;
  border-radius: 8px;
  cursor: pointer;
  transition: background 160ms var(--ease), box-shadow 160ms var(--ease);
}

/* Variante botón primario si quieres */
.select-role-header .btn-primary {
  background: var(--color-primary, #0b5cff);
  color: var(--color-white, #fff);
  border-color: transparent;
}

.select-role-header .btn-text:hover,
.select-role-header .btn-text:focus {
  background: rgba(11, 92, 255, 0.06);
  outline: none;
  box-shadow: 0 1px 2px rgba(16,24,40,0.04);
}

/* Accessibility focus */
.select-role-header a:focus,
.select-role-header button:focus {
  box-shadow: 0 0 0 3px rgba(11,92,255,0.12);
  border-radius: 8px;
}

/* --------------------------
   Layout principal y tarjeta
   -------------------------- */
.select-role-main {
  padding: var(--space-12, 48px) 0;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  min-height: calc(100vh - 80px);
  background: var(--bg-page, #fff);
}

.select-card {
  width: 100%;
  max-width: 520px;
  margin: 0 auto;
  padding: var(--space-8, 32px);
  border-radius: 28px;
  background: var(--bg-section, #fff);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-6, 20px);
  box-shadow: 0 8px 30px rgba(16,24,40,0.06);
  border: 1px solid rgba(15, 23, 42, 0.03);
}

.select-title {
  font-size: var(--font-size-lg, 20px);
  color: var(--color-title, #0f172a);
  font-weight: var(--font-weight-semibold, 600);
  margin: 0;
  text-align: center;
}

/* Campo / select */
.field {
  width: 100%;
  max-width: 360px;
  display: flex;
  flex-direction: column;
  gap: var(--space-2, 8px);
  align-items: stretch;
}

select.input {
  -webkit-appearance: none;
  appearance: none;
  background: var(--color-white, #fff);
  border: 1px solid var(--gray-300, #d1d5db);
  padding: 0.65rem 0.9rem;
  border-radius: 10px;
  font-size: var(--font-size-md, 16px);
  cursor: pointer;
  color: var(--color-body, #0f172a);
  transition: border-color 120ms var(--ease);
}

select.input:focus {
  border-color: var(--color-primary, #0b5cff);
  box-shadow: 0 4px 14px rgba(11,92,255,0.06);
  outline: none;
}

/* Arrow indicator (pure CSS) */
select.input {
  background-image: linear-gradient(45deg, transparent 50%, var(--color-text, #111827) 50%),
                    linear-gradient(135deg, var(--color-text, #111827) 50%, transparent 50%);
  background-position: calc(100% - 18px) calc(1rem + 2px), calc(100% - 12px) calc(1rem + 2px);
  background-size: 6px 6px, 6px 6px;
  background-repeat: no-repeat;
  padding-right: 2.5rem;
}

/* Helper text and actions */
.helper {
  color: var(--text-secondary, #6b7280);
  font-size: var(--font-size-sm, 13px);
}

.actions {
  display: flex;
  gap: var(--space-4, 16px);
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-top: var(--space-4, 16px);
}

.btn-next {
  background: var(--color-primary, #0b5cff);
  color: var(--color-white, #fff);
  padding: 0.58rem 1.25rem;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  font-weight: var(--font-weight-medium, 500);
  transition: transform 120ms var(--ease), opacity 120ms var(--ease);
}

.btn-next:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

/* --------------------------
   Responsive
   -------------------------- */
@media (max-width: 760px) {
  .select-card {
    padding: var(--space-6, 20px);
    border-radius: 16px;
    margin: 0 20px;
  }
  .select-role-header .header-inner {
    padding: 0;
  }
  .select-role-header .brand-logo {
    height: 34px;
  }
  select.input {
    font-size: 15px;
  }
}

@media (max-width: 420px) {
  .select-role-header .brand-logo { height: 30px; }
  .select-role-header .btn-text { padding: 6px 8px; font-size: 14px; }
  .select-card { padding: 16px; }
}

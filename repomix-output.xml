  },

  // Foreign key: business
  businessId: {
    type: DataTypes.INTEGER,
    allowNull: false,
    field: 'id_negocio',
  },

  // Creation timestamp
  createdAt: {
    type: DataTypes.DATE,
    defaultValue: DataTypes.NOW,
    allowNull: false,
    field: 'fecha_creacion_servicio',
  },


import Joi from 'joi';

// Import authentication RegEx
import { userAuthToken } from '../utils/regEx/authRegEx.js';

// Import user RegEx
import {
  ID,
  roleId,
  genderId,
  documentTypeId,
  firstName,
  lastName,
  birthDate,
  documentNumber,
  email,
  username,
  password,
} from '../utils/regEx/userRegEx.js';


// SERVICE SCHEMA — Joi Validation
// Entity: Service | Table: servicio
// ─────────────────────────────────────────────────────────────────────────────

import Joi from 'joi';

import {
  ID,
  name,
  description,
  price,
  categoryId,
  statusId,
  ageRestrictionId,
  businessId,
} from '../utils/regEx/serviceRegEx.js';


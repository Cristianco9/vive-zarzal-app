  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
  display: block;
}

/* Inputs */
.input {
  width: 100%;
  padding: 0.5rem 0.75rem;
  border-radius: 6px;
  border: 1px solid var(--gray-300);
  font-size: var(--font-size-md);
  background: var(--color-white);
  margin-bottom: var(--space-5);
  box-sizing: border-box;
  transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
}

.input:focus {
  outline: none;
  border-color: var(--color-accent);
  box-shadow: 0 0 0 4px rgba(23,162,184,0.06); /* subtle accent glow */
}

/* Actions row: login + register */
.form-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  margin-top: var(--space-4);
}

/* Primary login button — yellow pill */
.btn-login {
  background: var(--color-primary-light);
  color: var(--color-black);
  padding: 0.5rem 1.1rem;
  border-radius: 8px;
  border: 0;
  font-weight: var(--font-weight-medium);
  cursor: pointer;
  transition: transform var(--transition-fast), background var(--transition-fast);
}

.btn-login:hover,
.btn-login:focus {
  background: var(--color-primary);
  color: var(--color-white);
  transform: translateY(-2px);
}

/* Register link styled as subtle button/ghost to the right of login */
.btn-register {
  display: inline-block;
  padding: 0.45rem 0.9rem;
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,0.06);
  color: var(--text-primary);
  background: transparent;
  text-decoration: none;
  font-weight: var(--font-weight-medium);
  cursor: pointer;
}

/* Header "back" button (blue) */
.btn-back {
  display: inline-block;
  background: var(--color-brand-blue);
  color: var(--color-white);
  padding: 0.45rem 1rem;
  border-radius: 8px;
  text-decoration: none;
  font-weight: var(--font-weight-medium);
  box-shadow: 0 1px 0 rgba(0,0,0,0.06);
  transition: background var(--transition-fast), transform var(--transition-fast);
}

.btn-back:hover,
.btn-back:focus {
  transform: translateY(-1px);
  opacity: 0.95;
}

.form-error {
  color: #d9534f; /* bootstrap danger-ish red */
  font-size: var(--font-size-sm);
  margin-bottom: var(--space-3);
  text-align: center;
  display: none;
}

/* Responsive adjustments */
@media (max-width: 600px) {
  .login-card {
    padding: var(--space-6);
    border-radius: 32px;
  }

  .login-wrapper {
    padding: 0 var(--space-4);
  }

  .login-title {
    font-size: var(--font-size-md);
  }
}

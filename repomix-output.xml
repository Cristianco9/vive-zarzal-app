        ON DELETE CASCADE,

    CONSTRAINT fk_serviciofavorito_servicio
        FOREIGN KEY (id_servicio)
        REFERENCES Servicio(id_servicio)
        ON DELETE CASCADE,

    CONSTRAINT uq_servicio_favorito
        UNIQUE(id_usuario_favorito, id_servicio)
);


    type: DataTypes.DATE,
    defaultValue: DataTypes.NOW,
    allowNull: false,
    field: 'fecha_modificacion_servicio',
  },

}, {
  sequelize,
  tableName: SERVICE_TABLE,
  modelName: 'service',
  timestamps: true,
  
  // Map Sequelize timestamps to database columns
